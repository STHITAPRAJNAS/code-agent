# ── LLM ────────────────────────────────────────────────────────────────
GOOGLE_API_KEY=your_google_api_key_here
GEMINI_MODEL=gemini-2.0-flash

# ── GitHub ─────────────────────────────────────────────────────────────
GITHUB_TOKEN=your_github_personal_access_token
GITHUB_ORG=your_github_org_name

# ── Bitbucket Cloud ────────────────────────────────────────────────────
BITBUCKET_USERNAME=your_bitbucket_username
BITBUCKET_APP_PASSWORD=your_bitbucket_app_password
BITBUCKET_WORKSPACE=your_bitbucket_workspace_slug

# ── Bitbucket Server / Data Center (optional) ──────────────────────────
BITBUCKET_SERVER_URL=https://bitbucket.yourcompany.com
BITBUCKET_SERVER_TOKEN=your_bitbucket_server_personal_access_token
BITBUCKET_SERVER_PROJECT=YOUR_PROJECT_KEY

# ── Jira ───────────────────────────────────────────────────────────────
JIRA_SERVER_URL=https://yourcompany.atlassian.net
JIRA_USERNAME=your_email@company.com
JIRA_API_TOKEN=your_jira_api_token

# ── Confluence (optional) ──────────────────────────────────────────────
CONFLUENCE_SERVER_URL=https://yourcompany.atlassian.net/wiki
CONFLUENCE_USERNAME=your_email@company.com
CONFLUENCE_API_TOKEN=your_confluence_api_token

# ── Storage ────────────────────────────────────────────────────────────
WORKSPACE_DIR=/tmp/code_agent_workspaces
CHROMA_PATH=./chroma_db
CHROMA_COLLECTION=code_knowledge

# ── Performance ────────────────────────────────────────────────────────
EMBEDDING_BATCH_SIZE=50
MAX_CLONE_WORKERS=4
SHALLOW_CLONE_DEPTH=1

# ── Server ─────────────────────────────────────────────────────────────
APP_HOST=0.0.0.0
APP_PORT=8000
LOG_LEVEL=INFO

# ── Deployment ─────────────────────────────────────────────────────────
# "local" for development, "eks" for cloud deployment
DEPLOYMENT_MODE=local

# ── Aurora PostgreSQL (EKS mode only) ──────────────────────────────────
# Used for: session persistence + pgvector RAG store
DATABASE_URL=postgresql+asyncpg://codeagent:password@aurora-cluster.cluster-abc.us-east-1.rds.amazonaws.com:5432/codeagent
PGVECTOR_TABLE=code_knowledge

# ── Vertex AI RAG (optional, EKS mode) ────────────────────────────────
# Leave empty to use pgvector instead
VERTEX_RAG_CORPUS=
