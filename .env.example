# ── LLM Backend ──────────────────────────────────────────────────────────────
# Get your key at https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=your_google_api_key_here

# Set to FALSE to use Google AI Studio (default), TRUE for Vertex AI
GOOGLE_GENAI_USE_VERTEXAI=FALSE

# ── Server ────────────────────────────────────────────────────────────────────
APP_HOST=0.0.0.0
APP_PORT=8000

# ── Agent ─────────────────────────────────────────────────────────────────────
# Default working directory for file/shell/git operations
AGENT_WORKSPACE=/tmp/code-agent-workspace

# Gemini model to use (gemini-2.0-flash is fast and capable)
GEMINI_MODEL=gemini-2.0-flash
